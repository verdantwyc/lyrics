---
interface Props {
  indexUrl: string;
}

const { indexUrl } = Astro.props;
---

<div class="search-panel" data-search-panel data-index-url={indexUrl}>
  <button class="search-trigger" type="button" data-search-open>
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="m21 21-4.34-4.34"></path>
      <circle cx="11" cy="11" r="8"></circle>
    </svg>
    <span>搜索</span>
  </button>
  <div class="search-popover" hidden>
    <div class="search-box">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m21 21-4.34-4.34"></path>
        <circle cx="11" cy="11" r="8"></circle>
      </svg>
      <input data-search-input placeholder="输入歌名、歌词、人名、专辑..." />
      <button type="button" aria-label="关闭搜索" data-search-close>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
    </div>
    <div class="search-results" data-search-results>
      <p>可以搜歌名，也可以搜歌词正文、作词、作曲、编曲或专辑。</p>
    </div>
  </div>
</div>

<script>
  const fields = [
    ['title', 12],
    ['vocalist', 8],
    ['lyricist', 7],
    ['composer', 7],
    ['arranger', 6],
    ['producer', 5],
    ['recording', 5],
    ['mixer', 5],
    ['mastering', 5],
    ['album', 5],
    ['body', 2],
  ];

  const escapeHtml = (value) =>
    String(value ?? '').replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    }[char]));

  const scoreItem = (item, query) => {
    const q = query.toLowerCase();
    let score = 0;
    for (const [field, weight] of fields) {
      const text = String(item[field] || '').toLowerCase();
      const index = text.indexOf(q);
      if (index >= 0) score += weight + Math.max(0, 4 - index / 12);
    }
    const roleText = (item.roles || []).join(' ').toLowerCase();
    const roleIndex = roleText.indexOf(q);
    if (roleIndex >= 0) score += 4 + Math.max(0, 4 - roleIndex / 12);
    return score;
  };

  const snippet = (item, query) => {
    const text = item.body || `${item.vocalist || ''} ${item.lyricist || ''} ${item.composer || ''} ${item.arranger || ''} ${item.producer || ''} ${item.recording || ''} ${item.mixer || ''} ${item.mastering || ''}`;
    const index = text.toLowerCase().indexOf(query.toLowerCase());
    if (index < 0) return text.slice(0, 78);
    return text.slice(Math.max(0, index - 26), index + query.length + 52);
  };

  document.querySelectorAll('[data-search-panel]').forEach((panel) => {
    const openButton = panel.querySelector('[data-search-open]');
    const closeButton = panel.querySelector('[data-search-close]');
    const popover = panel.querySelector('.search-popover');
    const input = panel.querySelector('[data-search-input]');
    const results = panel.querySelector('[data-search-results]');
    const indexUrl = panel.getAttribute('data-index-url');
    let items = [];
    let loaded = false;

    const setOpen = async (open) => {
      panel.classList.toggle('is-open', open);
      popover.hidden = !open;
      if (!open) return;
      if (!loaded) {
        loaded = true;
        try {
          items = await fetch(indexUrl).then((response) => response.json());
        } catch {
          items = [];
        }
      }
      input.focus();
    };

    const render = () => {
      const query = input.value.trim();
      if (!query) {
        results.innerHTML = '<p>可以搜歌名，也可以搜歌词正文、作词、作曲、编曲或专辑。</p>';
        return;
      }
      const matches = items
        .map((item) => ({ item, score: scoreItem(item, query) }))
        .filter((entry) => entry.score > 0)
        .sort((a, b) => b.score - a.score)
        .slice(0, 8);
      if (!matches.length) {
        results.innerHTML = '<p>没有找到匹配的歌曲。</p>';
        return;
      }
      results.innerHTML = matches.map(({ item }) => {
        const tags = [...(item.roles || []), item.isOriginalVocal ? '原唱' : ''].filter(Boolean).join(' · ');
        return `<a href="${escapeHtml(item.href)}" class="search-result">
          <strong>${escapeHtml(item.title)}</strong>
          <span>${escapeHtml(item.album)} / ${escapeHtml(tags)}</span>
          <small>${escapeHtml(snippet(item, query))}</small>
        </a>`;
      }).join('');
    };

    openButton.addEventListener('click', () => setOpen(true));
    closeButton.addEventListener('click', () => setOpen(false));
    input.addEventListener('input', render);
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setOpen(false);
    });
    document.addEventListener('pointerdown', (event) => {
      if (!panel.contains(event.target)) setOpen(false);
    });
  });
</script>
