---
import { getCollection } from 'astro:content';
import SongCard from '../../components/SongCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { roleConfig, roleHref, roles, withBase, workTypeConfig, type Role } from '../../config/site';
import { isOriginalVocal, originalCount as getOriginalCount, roleCounts as getRoleCounts, songRoles, vocalCount as getVocalCount } from '../../utils/songMeta';

const roleBySlug = Object.fromEntries(roles.map((role) => [roleConfig[role].slug, role])) as Record<string, Role>;

export async function getStaticPaths() {
  return [
    { params: { category: 'original' } },
    { params: { category: 'vocal' } },
    ...roles.map((role) => ({ params: { category: roleConfig[role].slug } })),
  ];
}

const category = Astro.params.category ?? 'original';
const songs = (await getCollection('songs')).filter((song) => !song.data.draft);
const roleCounts = getRoleCounts(songs);
const originalCount = getOriginalCount(songs);
const vocalCount = getVocalCount(songs);

const role = roleBySlug[category];
const filtered = role
  ? songs.filter((song) => songRoles(song.data).includes(role))
  : category === 'vocal'
    ? songs.filter((song) => isOriginalVocal(song.data))
    : songs.filter((song) => songRoles(song.data).length > 0);

const title = role ? roleConfig[role].label : workTypeConfig[category as 'original' | 'vocal'].label;
const description = role ? roleConfig[role].description : workTypeConfig[category as 'original' | 'vocal'].description;
const roleGrid = {
  作词: 'grid-column: 4 / 7; grid-row: 3 / 4;',
  作曲: 'grid-column: 4 / 7; grid-row: 4 / 5;',
  编曲: 'grid-column: 4 / 7; grid-row: 5 / 6;',
} satisfies Record<Role, string>;
---

<BaseLayout title={title} description={description}>
  <section class="page-heading">
    <p class="eyebrow">category</p>
    <h1>{title}</h1>
    <p>{description}</p>
  </section>
  <section class="category-archive" aria-label="作品分类柜">
    <div class="cabinet-title">作品分类柜</div>
    <a class={`hero-stat hero-stat--large category-archive__primary ${category === 'original' ? 'is-current' : ''}`} href={withBase('/category/original')} style="grid-column: 1 / 7; grid-row: 1 / 3;">
      <strong class="stat-title">原创作品</strong>
      <span class="stat-label">{originalCount} 首</span>
    </a>
    <a class={`hero-stat hero-stat--large category-archive__vocal ${category === 'vocal' ? 'is-current' : ''}`} href={withBase('/category/vocal')} style="grid-column: 1 / 4; grid-row: 3 / 6;">
      <strong class="stat-title">原唱作品</strong>
      <span class="stat-label">{vocalCount} 首</span>
    </a>
    {roles.map((role) => (
      <a class={`hero-stat category-archive__role category-archive__role--${roleConfig[role].slug} ${category === roleConfig[role].slug ? 'is-current' : ''}`} href={roleHref(role)} style={roleGrid[role]}>
        <strong class="stat-number">{roleCounts[role]}</strong>
        <span class="stat-label">{role}</span>
      </a>
    ))}
  </section>
  <section class="card-grid">
    {filtered.map((song) => <SongCard song={song} />)}
  </section>
</BaseLayout>
